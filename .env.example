# MapTiler Cloud API key
# Get yours at: https://cloud.maptiler.com/account/keys/
MAPTILER_API_KEY=your-maptiler-api-key-here
MAPTILER_DATASET_ID=0198c878-963a-7ce5-bf1b-5a5ce575eff2

# =============================================================================
# GitHub OAuth App — create TWO separate apps at https://github.com/settings/developers
#
#   App 1 (localhost):
#     Homepage URL:         http://localhost:3000
#     Authorization callback URL: http://localhost:3000/api/auth/callback/github
#
#   App 2 (production):
#     Homepage URL:         https://alversjomaps.vercel.app
#     Authorization callback URL: https://alversjomaps.vercel.app/api/auth/callback/github
#
# For LOCAL dev (.env at repo root), use App 1 credentials + NEXTAUTH_URL=http://localhost:3000
# For PRODUCTION (Vercel dashboard env vars), use App 2 credentials + NEXTAUTH_URL=https://alversjomaps.vercel.app
# =============================================================================
AUTH_GITHUB_ID=your-localhost-oauth-app-client-id
AUTH_GITHUB_SECRET=your-localhost-oauth-app-client-secret

# GitHub fine-grained PAT — create at https://github.com/settings/tokens?type=beta
# Repository access: only alversjo-maps | Permission: Contents = Read and Write
# Same token can be used for both local and production
GITHUB_TOKEN=your-github-pat-here
GITHUB_OWNER=AntonFrisk
GITHUB_REPO=alversjo-maps

# NextAuth secret — generate with: openssl rand -base64 32
# Same value can be shared between local and production
AUTH_SECRET=your-random-auth-secret

# Change to https://alversjomaps.vercel.app in production Vercel env vars
NEXTAUTH_URL=http://localhost:3000